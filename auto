<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CLIPR AUTOPILOT</title>
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080808;
  --surface: #0f0f0f;
  --card: #141414;
  --border: #1e1e1e;
  --border2: #2a2a2a;
  --text: #e8e8e8;
  --muted: #555;
  --mid: #2e2e2e;
  --twitch: #9146ff;
  --kick: #53fc18;
  --tiktok: #ff0050;
  --youtube: #ff0000;
  --instagram: #e1306c;
  --green: #53fc18;
  --red: #ff2d2d;
  --amber: #ffaa00;
  --cyan: #00d4ff;
  --white: #ffffff;
}

* { margin:0;padding:0;box-sizing:border-box; }
html,body { height:100%;overflow:hidden; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Archivo', sans-serif;
  display: flex;
  flex-direction: column;
}

/* TOPBAR */
.topbar {
  display: flex;
  align-items: center;
  padding: 0 28px;
  height: 52px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  gap: 32px;
  flex-shrink: 0;
}

.logo {
  font-family: 'Archivo Black', sans-serif;
  font-size: 18px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--white);
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--green);
  background: rgba(83,252,24,.1);
  border: 1px solid rgba(83,252,24,.25);
  padding: 3px 8px;
  border-radius: 3px;
}

.topbar-nav {
  display: flex;
  gap: 2px;
  flex: 1;
}

.nav-tab {
  padding: 6px 16px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--muted);
  cursor: pointer;
  border-radius: 4px;
  transition: all .15s;
  border: none;
  background: none;
  font-family: 'Archivo', sans-serif;
}
.nav-tab:hover { color: var(--text); background: var(--border); }
.nav-tab.active { color: var(--white); background: var(--mid); }

.topbar-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.status-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .5px;
  font-family: 'JetBrains Mono', monospace;
}

.pill-green { background: rgba(83,252,24,.1); border: 1px solid rgba(83,252,24,.25); color: var(--green); }
.pill-amber { background: rgba(255,170,0,.1); border: 1px solid rgba(255,170,0,.25); color: var(--amber); }
.pill-red { background: rgba(255,45,45,.1); border: 1px solid rgba(255,45,45,.25); color: var(--red); }
.pill-muted { background: var(--card); border: 1px solid var(--border); color: var(--muted); }

.blink { animation: blink .8s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

.pulse-dot { width:7px;height:7px;border-radius:50%; }
.dot-green { background:var(--green); }
.dot-amber { background:var(--amber); }
.dot-red { background:var(--red); }
.dot-muted { background:var(--muted); }

/* MAIN LAYOUT */
.main {
  display: grid;
  grid-template-columns: 260px 1fr 280px;
  flex: 1;
  overflow: hidden;
}

/* SIDEBAR */
.sidebar {
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.sidebar-section {
  padding: 18px 16px;
  border-bottom: 1px solid var(--border);
}

.sidebar-title {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2.5px;
  color: var(--muted);
  margin-bottom: 12px;
}

/* CHANNEL CARDS */
.channel-list { display:flex;flex-direction:column;gap:6px; }

.channel-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 10px 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  transition: all .15s;
  position: relative;
}
.channel-card:hover { border-color: var(--border2); }
.channel-card.active { border-color: var(--mid); background: #1a1a1a; }

.ch-avatar {
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  flex-shrink: 0;
  font-family: 'Archivo Black', sans-serif;
}

.ch-info { flex:1;min-width:0; }
.ch-name { font-size: 13px; font-weight: 600; white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
.ch-platform { font-size: 10px; margin-top: 1px; display:flex;align-items:center;gap:4px; }

.ch-live {
  font-size: 9px; font-weight: 700; letter-spacing:.5px;
  background: rgba(255,45,45,.15); color: var(--red);
  border: 1px solid rgba(255,45,45,.3);
  padding: 2px 5px; border-radius: 3px;
}

.ch-toggle {
  width: 28px; height: 16px;
  background: var(--mid);
  border-radius: 8px;
  position: relative;
  cursor: pointer;
  flex-shrink: 0;
  transition: background .2s;
  border: none;
}
.ch-toggle.on { background: var(--green); }
.ch-toggle::after {
  content:'';
  position:absolute;
  width:12px;height:12px;
  background: white;
  border-radius:50%;
  top:2px;left:2px;
  transition: left .2s;
}
.ch-toggle.on::after { left: 14px; }

.add-channel-btn {
  width: 100%;
  padding: 8px;
  background: transparent;
  border: 1px dashed var(--border2);
  border-radius: 6px;
  color: var(--muted);
  font-size: 12px;
  font-family: 'Archivo', sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: all .15s;
  margin-top: 8px;
  letter-spacing: .5px;
}
.add-channel-btn:hover { color: var(--text); border-color: var(--mid); }

/* PIPELINE SETTINGS */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}
.setting-row:last-child { margin-bottom: 0; }
.setting-label { font-size: 11px; color: var(--muted); }
.setting-val { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text); }

.mini-select {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 4px; padding: 4px 8px;
  color: var(--text); font-family:'Archivo',sans-serif;
  font-size:11px; outline:none; cursor:pointer;
}
.mini-select:focus { border-color: var(--mid); }

/* TOGGLE SWITCH */
.toggle-wrap { display:flex;align-items:center;gap:8px; }
.toggle {
  width:32px;height:18px;background:var(--mid);border-radius:9px;
  position:relative;cursor:pointer;transition:background .2s;border:none;flex-shrink:0;
}
.toggle.on { background:var(--green); }
.toggle::after { content:'';position:absolute;width:14px;height:14px;background:white;border-radius:50%;top:2px;left:2px;transition:left .2s; }
.toggle.on::after { left:16px; }

/* CENTER PANEL */
.center-panel {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg);
}

/* PIPELINE FLOW */
.pipeline-header {
  padding: 20px 24px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pipeline-title {
  font-family: 'Archivo Black', sans-serif;
  font-size: 22px;
  letter-spacing: 1px;
  display: flex;
  align-items: baseline;
  gap: 10px;
}

.pipeline-subtitle {
  font-size: 12px;
  color: var(--muted);
  font-weight: 400;
  letter-spacing: 0;
  font-family: 'Archivo', sans-serif;
}

.run-btn {
  padding: 10px 24px;
  background: var(--green);
  color: #000;
  border: none;
  border-radius: 5px;
  font-family: 'Archivo Black', sans-serif;
  font-size: 13px;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all .15s;
  display: flex;
  align-items: center;
  gap: 8px;
}
.run-btn:hover { background: #6fff30; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(83,252,24,.3); }
.run-btn.running { background: var(--amber); color: #000; }
.run-btn.running:hover { background: #ffbb22; }

/* PIPELINE STAGES */
.pipeline-stages {
  display: flex;
  align-items: stretch;
  gap: 0;
  padding: 20px 24px;
  overflow-x: auto;
}

.stage {
  flex: 1;
  min-width: 120px;
  display: flex;
  flex-direction: column;
  position: relative;
}

.stage-connector {
  width: 32px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 28px;
}

.connector-line {
  width: 100%;
  height: 2px;
  background: var(--border2);
  position: relative;
  overflow: hidden;
}

.connector-line.active::after {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 100%; height: 100%;
  background: linear-gradient(90deg, transparent, var(--green), transparent);
  animation: flowLine 1.5s linear infinite;
}

@keyframes flowLine { to { left: 200%; } }

.connector-arrow {
  width: 0;height: 0;
  border-top: 5px solid transparent;
  border-bottom: 5px solid transparent;
  border-left: 7px solid var(--border2);
  flex-shrink: 0;
}
.connector-arrow.active { border-left-color: var(--green); }

.stage-box {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px;
  transition: all .2s;
  position: relative;
  overflow: hidden;
}

.stage-box.done { border-color: rgba(83,252,24,.3); }
.stage-box.running { border-color: rgba(255,170,0,.4); }
.stage-box.error { border-color: rgba(255,45,45,.3); }
.stage-box.idle { border-color: var(--border); }

.stage-box.running::before {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 200%; height: 3px;
  background: linear-gradient(90deg, transparent, var(--amber), transparent);
  animation: stageScan 1.8s linear infinite;
}

@keyframes stageScan { to { left: 100%; } }

.stage-icon {
  font-size: 20px;
  margin-bottom: 8px;
  display: block;
}

.stage-name {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  margin-bottom: 3px;
}

.stage-status {
  font-size: 12px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 6px;
  font-family: 'JetBrains Mono', monospace;
}

.stage-detail {
  font-size: 10px;
  color: var(--muted);
  line-height: 1.5;
}

.stage-badge {
  display: inline-block;
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 10px;
  font-weight: 700;
  margin-top: 4px;
  font-family: 'JetBrains Mono', monospace;
}

.badge-done { background: rgba(83,252,24,.15); color: var(--green); }
.badge-running { background: rgba(255,170,0,.15); color: var(--amber); }
.badge-queued { background: var(--mid); color: var(--muted); }
.badge-error { background: rgba(255,45,45,.15); color: var(--red); }

/* ACTIVITY FEED */
.activity-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 24px 16px;
  min-height: 0;
}

.activity-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.section-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--muted);
}

.clear-btn {
  font-size: 11px; color: var(--muted); background: none; border: none;
  cursor: pointer; font-family: 'Archivo', sans-serif;
  transition: color .15s;
}
.clear-btn:hover { color: var(--text); }

.activity-feed {
  flex: 1;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  overflow-y: auto;
  padding: 8px;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.log-line {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 5px 6px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  line-height: 1.5;
  transition: background .1s;
}
.log-line:hover { background: var(--card); }

.log-time { color: var(--muted); flex-shrink:0;width:50px; }
.log-icon { flex-shrink:0;width:14px;text-align:center; }
.log-text { flex:1; }
.log-text.ok { color: var(--green); }
.log-text.warn { color: var(--amber); }
.log-text.err { color: var(--red); }
.log-text.info { color: var(--cyan); }
.log-text.dim { color: var(--muted); }

/* RIGHT PANEL */
.right-panel {
  background: var(--surface);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.rp-section {
  padding: 16px;
  border-bottom: 1px solid var(--border);
}

.rp-title {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2.5px;
  color: var(--muted);
  margin-bottom: 12px;
}

/* STATS */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.stat-box {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 10px 12px;
}

.stat-val {
  font-family: 'Archivo Black', sans-serif;
  font-size: 22px;
  color: var(--white);
  line-height: 1;
  margin-bottom: 3px;
}

.stat-val.green { color: var(--green); }
.stat-val.amber { color: var(--amber); }
.stat-val.twitch { color: var(--twitch); }
.stat-val.kick-col { color: var(--kick); }

.stat-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* CLIP QUEUE PREVIEW */
.queue-list { display:flex;flex-direction:column;gap:6px; }

.queue-item {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 9px 11px;
  display: flex;
  gap: 9px;
  align-items: center;
}

.q-thumb {
  width: 44px; height: 28px;
  background: var(--mid);
  border-radius: 3px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: var(--muted);
  overflow: hidden;
  position: relative;
}

.q-info { flex:1;min-width:0; }
.q-title { font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
.q-meta { font-size:10px;color:var(--muted);margin-top:2px;display:flex;gap:6px;align-items:center; }

.q-status-dot {
  width:6px;height:6px;border-radius:50%;flex-shrink:0;
}

.platform-icons { display:flex;gap:3px;margin-top:4px; }
.picon {
  width:14px;height:14px;border-radius:3px;
  display:flex;align-items:center;justify-content:center;
  font-size:8px;
}
.picon-tt { background:rgba(255,0,80,.2);color:var(--tiktok); }
.picon-yt { background:rgba(255,0,0,.2);color:var(--youtube); }
.picon-ig { background:rgba(225,48,108,.2);color:var(--instagram); }

/* POST TARGETS */
.target-list { display:flex;flex-direction:column;gap:6px; }
.target-item {
  display:flex;align-items:center;gap:10px;
  background:var(--card);border:1px solid var(--border);
  border-radius:6px;padding:9px 11px;
}
.target-icon { width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0; }
.t-tt { background:rgba(255,0,80,.15); }
.t-yt { background:rgba(255,0,0,.15); }
.t-ig { background:rgba(225,48,108,.15); }
.target-info { flex:1; }
.target-name { font-size:12px;font-weight:600; }
.target-status { font-size:10px;color:var(--muted);margin-top:1px; }
.target-status.ok { color:var(--green); }
.target-count { font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted); }

/* SCHEDULE SETTINGS */
.sched-items { display:flex;flex-direction:column;gap:8px; }
.sched-row {
  display:flex;align-items:center;justify-content:space-between;
}
.sched-label { font-size:11px;color:var(--muted); }
.sched-badge {
  font-family:'JetBrains Mono',monospace;font-size:10px;
  padding:3px 8px;border-radius:3px;
  background:var(--card);border:1px solid var(--border);color:var(--text);
}

/* MODAL */
.modal-overlay {
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.85);z-index:200;
  align-items:center;justify-content:center;
  backdrop-filter:blur(6px);
}
.modal-overlay.show { display:flex; }
.modal {
  background:var(--card);border:1px solid var(--border2);
  border-radius:12px;padding:28px;width:460px;max-width:90vw;
  animation:modalIn .2s ease;
}
@keyframes modalIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

.modal-title {
  font-family:'Archivo Black',sans-serif;font-size:20px;letter-spacing:1px;
  margin-bottom:6px;
}
.modal-sub { font-size:12px;color:var(--muted);margin-bottom:20px;line-height:1.5; }

.modal-field { margin-bottom:12px; }
.field-label { font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);font-weight:700;margin-bottom:5px;display:block; }
.field-input {
  width:100%;background:var(--surface);border:1px solid var(--border);
  border-radius:6px;padding:9px 12px;color:var(--text);
  font-family:'JetBrains Mono',monospace;font-size:12px;outline:none;transition:border-color .15s;
}
.field-input:focus { border-color:var(--mid); }

.platform-pick { display:flex;gap:8px;margin-bottom:20px; }
.pp-btn {
  flex:1;padding:10px 6px;background:var(--surface);
  border:1px solid var(--border);border-radius:6px;
  cursor:pointer;text-align:center;transition:all .15s;
  font-family:'Archivo',sans-serif;
}
.pp-btn:hover { border-color:var(--mid); }
.pp-btn.active-twitch { border-color:var(--twitch);background:rgba(145,70,255,.1); }
.pp-btn.active-kick { border-color:var(--kick);background:rgba(83,252,24,.08); }
.pp-icon { font-size:20px;display:block;margin-bottom:4px; }
.pp-name { font-size:11px;font-weight:600;color:var(--muted); }
.pp-btn.active-twitch .pp-name { color:var(--twitch); }
.pp-btn.active-kick .pp-name { color:var(--kick); }

.modal-actions { display:flex;gap:8px;margin-top:20px; }
.mbtn { padding:10px 20px;border:none;border-radius:6px;font-family:'Archivo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .15s; }
.mbtn-primary { background:var(--white);color:#000;flex:2; }
.mbtn-primary:hover { background:#ddd; }
.mbtn-sec { background:var(--surface);color:var(--muted);border:1px solid var(--border);flex:1; }
.mbtn-sec:hover { color:var(--text); }

/* TOAST */
.toast {
  position:fixed;bottom:20px;left:50%;
  transform:translateX(-50%) translateY(60px);
  background:var(--card);border:1px solid var(--border2);
  border-radius:8px;padding:10px 18px;
  display:flex;align-items:center;gap:8px;
  font-size:12px;font-family:'JetBrains Mono',monospace;
  z-index:300;transition:transform .3s;white-space:nowrap;
}
.toast.show { transform:translateX(-50%) translateY(0); }
.toast.ok { border-color:rgba(83,252,24,.4); }
.toast.warn { border-color:rgba(255,170,0,.4); }

/* scrollbar */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--mid);border-radius:3px}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="logo">CLIPR <span class="logo-tag">AUTOPILOT</span></div>
  <div class="topbar-nav">
    <button class="nav-tab active" onclick="switchTab('pipeline',this)">Pipeline</button>
    <button class="nav-tab" onclick="switchTab('channels',this)">Channels</button>
    <button class="nav-tab" onclick="switchTab('settings',this)">Settings</button>
  </div>
  <div class="topbar-right">
    <div class="status-pill pill-muted" id="globalStatus">
      <span class="pulse-dot dot-muted" id="globalDot"></span>
      <span id="globalStatusText">IDLE</span>
    </div>
    <div class="status-pill pill-muted" id="nextRunPill">
      <span id="nextRunText">Next: —</span>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- SIDEBAR -->
  <div class="sidebar">

    <div class="sidebar-section">
      <div class="sidebar-title">Tracked Channels</div>
      <div class="channel-list" id="channelList"></div>
      <button class="add-channel-btn" onclick="openAddChannel()">+ Add Channel</button>
    </div>

    <div class="sidebar-section">
