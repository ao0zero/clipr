<script>
// ========== STATE ==========
let channels = [
  { id:1, name:'xQcOW', platform:'twitch', enabled:true, color:'#9146ff', emoji:'X', lastVod:null },
  { id:2, name:'KaiCenat', platform:'twitch', enabled:true, color:'#7c3aed', emoji:'K', lastVod:null },
  { id:3, name:'Adin Ross', platform:'kick', enabled:false, color:'#16a34a', emoji:'A', lastVod:null },
];

let connectedPlatforms = { tiktok:false, youtube:false, instagram:false };
let platformCreds = {};
let currentPlatformModal = null;
let selectedAddPlatform = 'twitch';
let pipelineRunning = false;
let stats = { clipsPosted:0, vodsScanned:0, twitchClips:0, kickClips:0 };
let queueItems = [];
let logLines = [];
let pollTimer = null;
let runCount = 0;

// Pipeline stages definition
const STAGES = [
  { id:'fetch',   icon:'📡', name:'Fetch VODs',    desc:'Poll Twitch & Kick APIs' },
  { id:'detect',  icon:'🧠', name:'AI Detect',     desc:'Find peak moments' },
  { id:'clip',    icon:'✂️', name:'Cut Clips',     desc:'Trim to target length' },
  { id:'caption', icon:'💬', name:'AI Caption',    desc:'Generate title & tags' },
  { id:'post',    icon:'🚀', name:'Auto-Post',     desc:'Push to platforms' },
];

let stageStates = { fetch:'idle', detect:'idle', clip:'idle', caption:'idle', post:'idle' };

// ========== INIT ==========
renderChannels();
renderPipelineStages();
renderQueue();
updateNextRun();
setInterval(updateNextRun, 30000);

// ========== CHANNELS ==========
function renderChannels() {
  const list = document.getElementById('channelList');
  list.innerHTML = channels.map(ch => `
    <div class="channel-card ${ch.enabled?'active':''}">
      <div class="ch-avatar" style="background:${ch.platform==='twitch'?'rgba(145,70,255,.2)':'rgba(83,252,24,.15)'};color:${ch.platform==='twitch'?'#9146ff':'#53fc18'}">${ch.emoji}</div>
      <div class="ch-info">
        <div class="ch-name">${ch.name}</div>
        <div class="ch-platform" style="color:${ch.platform==='twitch'?'#9146ff':'#53fc18'}">
          ${ch.platform==='twitch'?'💜':'🟢'} ${ch.platform.toUpperCase()}
          ${ch.lastVod?`<span class="ch-live">LIVE</span>`:''}
        </div>
      </div>
      <button class="ch-toggle ${ch.enabled?'on':''}" onclick="toggleChannel(${ch.id},this)"></button>
    </div>
  `).join('');
}

function toggleChannel(id, btn) {
  const ch = channels.find(c=>c.id===id);
  if(ch) { ch.enabled=!ch.enabled; btn.classList.toggle('on',ch.enabled); renderChannels(); }
}

// ========== PIPELINE ==========
function renderPipelineStages() {
  const el = document.getElementById('pipelineStages');
  let html = '';
  STAGES.forEach((s, i) => {
    const state = stageStates[s.id];
    html += `
      <div class="stage">
        <div class="stage-box ${state}" id="stage-${s.id}">
          <span class="stage-icon">${s.icon}</span>
          <div class="stage-name">${s.name}</div>
          <div class="stage-status" id="stage-status-${s.id}">${getStageStatusText(state)}</div>
          <div class="stage-detail" id="stage-detail-${s.id}">${s.desc}</div>
          <span class="stage-badge ${getBadgeClass(state)}" id="stage-badge-${s.id}">${getBadgeText(state)}</span>
        </div>
      </div>
    `;
    if(i < STAGES.length-1) {
      html += `
        <div class="stage-connector">
          <div class="connector-line ${state==='done'?'active':''}" id="conn-${s.id}"></div>
          <div class="connector-arrow ${state==='done'?'active':''}" id="arrow-${s.id}"></div>
        </div>
      `;
    }
  });
  el.innerHTML = html;
}

function getStageStatusText(s) {
  return {idle:'Waiting',running:'Processing...',done:'Complete',error:'Failed',queued:'Queued'}[s]||'—';
}
function getBadgeClass(s) {
  return {idle:'badge-queued',running:'badge-running',done:'badge-done',error:'badge-error',queued:'badge-queued'}[s]||'badge-queued';
}
function getBadgeText(s) {
  return {idle:'IDLE',running:'ACTIVE',done:'DONE',error:'ERR',queued:'QUEUE'}[s]||'IDLE';
}

function updateStage(id, state, statusText, detailText) {
  stageStates[id] = state;
  const box = document.getElementById('stage-'+id);
  if(box) { box.className = 'stage-box '+state; }
  const st = document.getElementById('stage-status-'+id);
  if(st) st.textContent = statusText||getStageStatusText(state);
  const dt = document.getElementById('stage-detail-'+id);
  if(dt && detailText) dt.textContent = detailText;
  const bd = document.getElementById('stage-badge-'+id);
  if(bd) { bd.className='stage-badge '+getBadgeClass(state); bd.textContent=getBadgeText(state); }
  // Update connectors
  const prevIdx = STAGES.findIndex(s=>s.id===id)-1;
  if(prevIdx>=0) {
    const prevId = STAGES[prevIdx].id;
    const conn = document.getElementById('conn-'+prevId);
    const arr = document.getElementById('arrow-'+prevId);
    if(state==='done'||state==='running') { conn?.classList.add('active'); arr?.classList.add('active'); }
  }
}

function sleep(ms) { return new Promise(r=>setTimeout(r,ms)); }

async function runPipeline() {
  if(pipelineRunning) return;
  const enabledChannels = channels.filter(c=>c.enabled);
  if(!enabledChannels.length) return showToast('No channels enabled', 'warn');

  pipelineRunning = true;
  runCount++;
  const btn = document.getElementById('runBtn');
  btn.classList.add('running');
  document.getElementById('runBtnText').textContent = 'RUNNING';
  document.getElementById('runBtnIcon').textContent = '⏳';

  setGlobalStatus('running');
  clearLog();

  // Reset stages
  STAGES.forEach(s => updateStage(s.id,'idle','Waiting',null));

  const now = new Date();
  const ts = now.toTimeString().slice(0,5);

  // ---- STAGE 1: FETCH ----
  updateStage('fetch','running','Polling APIs...',`Checking ${enabledChannels.length} channels`);
  log(ts,'📡','Polling Twitch API for new VODs...','info');
  await sleep(900);

  const twitchChs = enabledChannels.filter(c=>c.platform==='twitch');
  const kickChs = enabledChannels.filter(c=>c.platform==='kick');
  const newVods = [];

  for(const ch of twitchChs) {
    log(ts,'·',`twitch/${ch.name} — checking recent VODs`,'dim');
    await sleep(400);
    const vodCount = 1+Math.floor(Math.random()*2);
    newVods.push(...Array.from({length:vodCount},(_,i)=>({
      channel:ch.name, platform:'twitch',
      title:`${ch.name} Stream VOD ${runCount}-${i+1}`,
      duration: Math.floor(Math.random()*3600+1800),
      id:`twitch_${ch.id}_${runCount}_${i}`
    })));
    log(ts,'✓',`${ch.name}: ${vodCount} new VOD(s) found`,'ok');
  }

  for(const ch of kickChs) {
    log(ts,'·',`kick/${ch.name} — checking recent VODs`,'dim');
    await sleep(350);
    const vodCount = Math.floor(Math.random()*2);
    if(vodCount>0) {
      newVods.push(...Array.from({length:vodCount},(_,i)=>({
        channel:ch.name, platform:'kick',
        title:`${ch.name} Kick VOD ${runCount}-${i+1}`,
        duration: Math.floor(Math.random()*2400+1200),
        id:`kick_${ch.id}_${runCount}_${i}`
      })));
      log(ts,'✓',`${ch.name}: ${vodCount} new VOD(s) found`,'ok');
    } else {
      log(ts,'·',`${ch.name}: no new VODs`,'dim');
    }
  }

  stats.vodsScanned += newVods.length;
  updateStats();
  updateStage('fetch','done',`${newVods.length} VODs`,`Fetched from ${enabledChannels.length} channels`);

  if(!newVods.length) {
    log(ts,'ℹ','No new VODs found — pipeline complete','dim');
    STAGES.slice(1).forEach(s=>updateStage(s.id,'idle','Skipped','No VODs to process'));
    pipelineFinished(btn);
    return;
  }

  await sleep(300);

  // ---- STAGE 2: AI DETECT ----
  updateStage('detect','running','Analyzing...','Computing audio energy');
  log(ts,'🧠','Starting AI moment detection...','info');
  const allClips = [];

  for(const vod of newVods) {
    log(ts,'·',`Analyzing: ${vod.title.slice(0,40)}`,'dim');
    await sleep(600+Math.random()*400);
    const maxClips = parseInt(document.getElementById('clipsPerVod').value)||5;
    const numClips = 1+Math.floor(Math.random()*(maxClips));
    const dur = parseInt(document.getElementById('clipLenGlobal').value)||30;
    for(let i=0;i<numClips;i++) {
      const startT = Math.floor(Math.random()*(vod.duration-dur));
      allClips.push({
        id:`clip_${vod.id}_${i}`,
        vodId:vod.id, channel:vod.channel, platform:vod.platform,
        start:startT, end:startT+dur, duration:dur,
        score:0.6+Math.random()*0.4,
        title:vod.title
      });
    }
    log(ts,'✓',`Found ${numClips} hot moment(s) in ${vod.channel}'s VOD`,'ok');
  }

  updateStage('detect','done',`${allClips.length} moments`,`Across ${newVods.length} VODs`);
  await sleep(300);

  // ---- STAGE 3: CUT CLIPS ----
  updateStage('clip','running','Trimming...','Cutting to target length');
  log(ts,'✂️','Cutting clips to target length...','info');
  await sleep(800);
  log(ts,'✓',`${allClips.length} clips trimmed and encoded`,'ok');
  updateStage('clip','done',`${allClips.length} clips ready`,'Encoded for all platforms');
  await sleep(300);

  // ---- STAGE 4: AI CAPTIONS ----
  updateStage('caption','running','Generating...','AI writing captions');
  log(ts,'💬','Generating captions and hashtags with AI...','info');
  const captionTemplates = [
    ["POV: you're watching the most chaotic stream of the week 💀","#gaming #streamer #viral #clip #twitch"],
    ["bro really said that on live 💀😭","#streamer #funny #clip #viral #fyp"],
    ["this moment had the whole chat going crazy 🔥","#gaming #twitch #kick #viral #live"],
    ["CHAT WAS NOT READY 😭","#clip #streamer #gaming #fyp #viral"],
    ["the timing on this is INSANE 🤯","#gaming #stream #clip #twitch #reaction"],
  ];
  for(const clip of allClips) {
    const ct = captionTemplates[Math.floor(Math.random()*captionTemplates.length)];
    clip.caption = ct[0];
    clip.hashtags = ct[1];
    await sleep(100);
  }
  log(ts,'✓',`Captions generated for all ${allClips.length} clips`,'ok');
  updateStage('caption','done','Captions ready','AI-generated for all clips');
  await sleep(300);

  // ---- STAGE 5: POST ----
  const postPlatforms = Object.keys(connectedPlatforms).filter(p=>connectedPlatforms[p]);
  const postTargets = postPlatforms.length > 0 ? postPlatforms : ['tiktok','youtube','instagram'];
  updateStage('post','running','Posting...','Uploading to platforms');
  log(ts,'🚀',`Posting to ${postTargets.join(', ')}...`,'info');

  let posted = 0;
  let twitchCount = 0, kickCount = 0;

  for(const clip of allClips) {
    for(const plat of postTargets) {
      await sleep(300+Math.random()*200);
      log(ts,'✓',`Posted "${clip.title.slice(0,30)}..." → ${plat}`,'ok');
      posted++;
      if(clip.platform==='twitch') twitchCount++;
      else kickCount++;
    }
    // Add to queue display
    queueItems.unshift({
      ...clip,
      postedAt: new Date().toLocaleTimeString(),
      platforms: postTargets
    });
    if(queueItems.length>12) queueItems.pop();
    stats.clipsPosted += postTargets.length;
  }

  stats.twitchClips += twitchCount;
  stats.kickClips += kickCount;
  updateStats();
  renderQueue();

  log(ts,'🎉',`Pipeline complete — ${allClips.length} clips posted across ${postTargets.length} platform(s)`,'ok');
  updateStage('post','done',`${posted} posts sent`,`${allClips.length} clips × ${postTargets.length} platforms`);

  // Schedule preview
  renderSchedulePreview(allClips);

  setGlobalStatus('done');
  pipelineFinished(btn);
  showToast(`✓ ${allClips.length} clips auto-posted`);
}

function pipelineFinished(btn) {
  pipelineRunning = false;
  btn.classList.remove('running');
  document.getElementById('runBtnText').textContent = 'RUN NOW';
  document.getElementById('runBtnIcon').textContent = '▶';
  updateNextRun();
}

function setGlobalStatus(state) {
  const pill = document.getElementById('globalStatus');
  const dot = document.getElementById('globalDot');
  const text = document.getElementById('globalStatusText');
  if(state==='running') {
    pill.className='status-pill pill-amber';
    dot.className='pulse-dot dot-amber blink';
    text.textContent='RUNNING';
  } else if(state==='done') {
    pill.className='status-pill pill-green';
    dot.className='pulse-dot dot-green';
    text.textContent='COMPLETE';
    setTimeout(()=>setGlobalStatus('idle'),4000);
  } else {
    pill.className='status-pill pill-muted';
    dot.className='pulse-dot dot-muted';
    text.textContent='IDLE';
  }
}

// ========== LOG ==========
function log(ts, icon, text, type='') {
  const feed = document.getElementById('activityFeed');
  const line = document.createElement('div');
  line.className = 'log-line';
  line.innerHTML = `<span class="log-time">${ts}</span><span class="log-icon">${icon}</span><span class="log-text ${type}">${text}</span>`;
  feed.appendChild(line);
  feed.scrollTop = feed.scrollHeight;
  logLines.push({ts,icon,text,type});
}

function clearLog() {
  document.getElementById('activityFeed').innerHTML = '';
  logLines = [];
}

// ========== STATS ==========
function updateStats() {
  document.getElementById('statClipsPosted').textContent = stats.clipsPosted;
  document.getElementById('statVodsScanned').textContent = stats.vodsScanned;
  document.getElementById('statTwitchClips').textContent = stats.twitchClips;
  document.getElementById('statKickClips').textContent = stats.kickClips;
}

// ========== QUEUE ==========
function renderQueue() {
  const list = document.getElementById('queueList');
  document.getElementById('queueCount').textContent = queueItems.length;
  if(!queueItems.length) {
    list.innerHTML = '<div style="font-size:11px;color:var(--muted);text-align:center;padding:12px;">No clips in queue</div>';
    return;
  }
  list.innerHTML = queueItems.slice(0,6).map(item => {
    const platIcons = item.platforms.map(p=>{
      const cls = p==='tiktok'?'picon-tt':p==='youtube'?'picon-yt':'picon-ig';
      const ic = p==='tiktok'?'🎵':p==='youtube'?'▶':'📸';
      return `<span class="picon ${cls}">${ic}</span>`;
    }).join('');
    return `
      <div class="queue-item">
        <div class="q-thumb" style="background:${item.platform==='twitch'?'rgba(145,70,255,.2)':'rgba(83,252,24,.15)'}">
          <span style="font-size:16px;">${item.platform==='twitch'?'💜':'🟢'}</span>
        </div>
        <div class="q-info">
          <div class="q-title">${item.channel} · ${fmtTime(item.start)}-${fmtTime(item.end)}</div>
          <div class="q-meta">
            <span style="color:${item.platform==='twitch'?'#9146ff':'#53fc18'};font-size:9px;font-weight:700;text-transform:uppercase;">${item.platform}</span>
            <span>${item.postedAt}</span>
          </div>
          <div class="platform-icons">${platIcons}</div>
        </div>
      </div>`;
  }).join('');
}

function fmtTime(s) {
  return Math.floor(s/60)+':'+String(Math.floor(s%60)).padStart(2,'0');
}

// ========== SCHEDULE PREVIEW ==========
function renderSchedulePreview(clips) {
  const el = document.getElementById('schedulePreview');
  const spacing = document.getElementById('postSpacing').value.includes('30')?30:
                  document.getElementById('postSpacing').value.includes('2')?120:
                  document.getElementById('postSpacing').value.includes('4')?240:60;
  const now = new Date();
  el.innerHTML = clips.slice(0,4).map((c,i)=>{
    const postTime = new Date(now.getTime()+(i*spacing*60000));
    const hrs = String(postTime.getHours()).padStart(2,'0');
    const mins = String(postTime.getMinutes()).padStart(2,'0');
    return `
      <div style="display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border);border-radius:5px;padding:7px 10px;">
        <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--cyan);min-width:38px;">${hrs}:${mins}</span>
        <span style="font-size:11px;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${c.channel}</span>
        <span style="font-size:9px;color:${c.platform==='twitch'?'#9146ff':'#53fc18'};font-weight:700;text-transform:uppercase;">${c.platform}</span>
      </div>`;
  }).join('');
}

// ========== NEXT RUN ==========
function updateNextRun() {
  const interval = document.getElementById('pollInterval').value;
  const minutes = interval.includes('5 ')?5:interval.includes('15')?15:interval.includes('30')?30:60;
  const next = new Date(Date.now()+minutes*60000);
  const h=String(next.getHours()).padStart(2,'0'),m=String(next.getMinutes()).padStart(2,'0');
  document.getElementById('nextRunText').textContent=`Next: ${h}:${m}`;
}

// ========== ADD CHANNEL MODAL ==========
function openAddChannel() {
  selectPlatform('twitch');
  document.getElementById('channelNameInput').value='';
  document.getElementById('channelApiKey').value='';
  document.getElementById('channelApiSecret').value='';
  document.getElementById('addChannelModal').classList.add('show');
}

function selectPlatform(p) {
  selectedAddPlatform = p;
  document.getElementById('pp-twitch').className='pp-btn'+(p==='twitch'?' active-twitch':'');
  document.getElementById('pp-kick').className='pp-btn'+(p==='kick'?' active-kick':'');
  document.getElementById('apiKeyLabel').textContent = p==='twitch'?'Twitch Client ID':'Kick Channel ID (optional)';
  document.getElementById('apiSecretLabel').textContent = p==='twitch'?'Twitch Client Secret':'Kick Auth Token (optional)';
  document.getElementById('channelApiKey').placeholder = p==='twitch'?'Get from dev.twitch.tv':'Optional for public channels';
  document.getElementById('channelApiSecret').placeholder = p==='twitch'?'OAuth secret':'Optional';
}

function addChannel() {
  const name = document.getElementById('channelNameInput').value.trim();
  if(!name) return showToast('Enter a channel name','warn');
  const initials = name.slice(0,1).toUpperCase();
  channels.push({
    id: Date.now(), name, platform: selectedAddPlatform,
    enabled: true, color: selectedAddPlatform==='twitch'?'#9146ff':'#53fc18',
    emoji: initials, lastVod: null
  });
  renderChannels();
  closeModal('addChannelModal');
  showToast(`${name} added on ${selectedAddPlatform}`);
}

// ========== PLATFORM CONNECT ==========
function connectPlatform(p) {
  currentPlatformModal = p;
  const names = {tiktok:'TikTok',youtube:'YouTube Shorts',instagram:'Instagram Reels'};
  const steps = {
    tiktok: ['Go to developer.tiktok.com → Create App','Enable Content Posting API','Copy Client Key & Secret'],
    youtube: ['Go to console.cloud.google.com → Create Project','Enable YouTube Data API v3','Create OAuth 2.0 credentials'],
    instagram: ['Go to developers.facebook.com → Create App','Add Instagram Graph API product','Copy App ID & Access Token']
  };
  document.getElementById('cpTitle').textContent = 'Connect '+names[p];
  document.getElementById('cpSub').textContent = 'Follow the steps below, then paste your credentials.';
  document.getElementById('cpSteps').innerHTML = steps[p].map((s,i)=>`
    <div style="display:flex;gap:10px;background:var(--surface);padding:9px 12px;border-radius:5px;border:1px solid var(--border);">
      <span style="width:18px;height:18px;border-radius:50%;background:var(--mid);color:var(--text);font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;">${i+1}</span>
      <span style="font-size:12px;">${s}</span>
    </div>`).join('');
  document.getElementById('cpKey').value = platformCreds[p]?.key||'';
  document.getElementById('cpSecret').value = platformCreds[p]?.secret||'';
  document.getElementById('connectPlatformModal').classList.add('show');
}

function savePlatformCreds() {
  const key=document.getElementById('cpKey').value.trim();
  const secret=document.getElementById('cpSecret').value.trim();
  if(!key||!secret) return showToast('Enter both fields','warn');
  platformCreds[currentPlatformModal]={key,secret};
  connectedPlatforms[currentPlatformModal]=true;
  const names={tiktok:'TikTok',youtube:'YouTube Shorts',instagram:'Instagram Reels'};
  const statEl=document.getElementById({tiktok:'tt-stat',youtube:'yt-stat',instagram:'ig-stat'}[currentPlatformModal]);
  if(statEl){statEl.textContent='● Connected';statEl.className='target-status ok';}
  closeModal('connectPlatformModal');
  showToast(names[currentPlatformModal]+' connected ✓');
}

// ========== UTILS ==========
function closeModal(id) { document.getElementById(id).classList.remove('show'); }

function toggleSetting(btn) { btn.classList.toggle('on'); }

function switchTab(tab, el) {
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
}

function showToast(msg, type='ok') {
  const t=document.getElementById('toast');
  document.getElementById('toastMsg').textContent=msg;
  t.className='toast show '+(type==='warn'?'warn':'ok');
  setTimeout(()=>t.classList.remove('show'),2800);
}
</script>
